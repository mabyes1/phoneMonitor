            android:action="android.intent.action.VIEW"
            android:data="phonemonitor://open?mode=sideboard"
            android:targetClass="com.phonemonitor.app.MainActivity"
            android:targetPackage="com.phonemonitor.app" />
    </shortcut>
    <shortcut
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_quota"
        android:shortcutId="quota"
        android:shortcutLongLabel="@string/shortcut_quota_long"
        android:shortcutShortLabel="@string/shortcut_quota_short">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="phonemonitor://open?mode=quota"
            android:targetClass="com.phonemonitor.app.MainActivity"
            android:targetPackage="com.phonemonitor.app" />
    </shortcut>
</shortcuts>
