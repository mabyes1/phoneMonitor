{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "CustomSources": {
    "AllowInsecureLan": false,
    "MaxPayloadBytes": 65536,
    "RequestsPerSecond": 10,
    "Burst": 30,
    "CleanupIntervalSeconds": 30
  },
  "RemoteAccess": {
    "Password": ""
  }
}
